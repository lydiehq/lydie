{
  "name": "lydie",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@fluentui/react-icons": "^2.0.321",
      "@rocicorp/zero": "0.26.0",
      "sst": "v3.18.6",
      "zod": "^4.3.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "yjs": "^13.6.30",
      "drizzle-orm": "^1.0.0-beta.15-9485290",
      "better-auth": "^1.5.5",
      "@better-auth/drizzle-adapter": "^1.5.5",
      "@ai-sdk/google": "^3.0.43",
      "@ai-sdk/openai": "^3.0.41",
      "ai": "^6.0.116",
      "@tiptap/core": "^3.20.1",
      "@tiptap/pm": "^3.20.1",
      "@tiptap/react": "^3.20.1",
      "@tiptap/starter-kit": "^3.20.1",
      "@tiptap/y-tiptap": "^3.0.2",
      "@tiptap/extension-drag-handle": "^3.20.1",
      "@tiptap/extension-drag-handle-react": "^3.20.1",
      "@tiptap/extension-mention": "^3.20.1",
      "@tiptap/extension-node-range": "^3.20.1",
      "@tiptap/extension-placeholder": "^3.20.1",
      "stripe": "^20.4.1"
    }
  },
  "scripts": {
    "dev": "sh -c 'bun run docker:db:up; if [ \"${KEEP_DB_RUNNING:-0}\" = \"1\" ]; then sst dev; else trap \"bun run docker:db:down\" EXIT INT TERM; sst dev; fi'",
    "docker:dev": "docker compose --env-file .env -f docker/docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose --env-file .env -f docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env -f docker/docker-compose.dev.yml logs -f",
    "docker:db:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d postgres",
    "docker:db:down": "docker compose --env-file .env -f docker/docker-compose.yml stop postgres",
    "docker:db:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f postgres",
    "docker:prod": "docker compose --env-file .env -f docker/docker-compose.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env -f docker/docker-compose.yml down -v",
    "docker:prod:logs": "docker compose --env-file .env -f docker/docker-compose.yml logs -f",
    "docker:e2e": "sh -c 'BETTER_AUTH_ENABLE_TEST_UTILS=true VITE_API_URL=http://host.docker.internal:3000 VITE_ZERO_URL=http://host.docker.internal:3000 VITE_YJS_SERVER_URL=ws://host.docker.internal:3000/yjs docker compose --env-file .env -f docker/docker-compose.yml up -d --build --wait --wait-timeout 180; BETTER_AUTH_ENABLE_TEST_UTILS=true docker compose --env-file .env -f docker/docker-compose.yml --profile test run --rm e2e bunx playwright test \"$@\"; status=$?; docker compose --env-file .env -f docker/docker-compose.yml down -v; exit $status' --",
    "db:push": "bun --filter=@lydie/database db:push",
    "db:sync": "bun --filter=@lydie/database db:sync-zero-publication",
    "db:studio": "bun --filter=@lydie/database db:studio",
    "db:migrate": "bun --filter=@lydie/database db:migrate",
    "db:generate": "bun --filter=@lydie/database db:generate",
    "deploy:staging": "sst deploy --stage staging",
    "deploy:prod": "sst deploy --stage production",
    "deploy:web": "sst deploy --target Web --stage production",
    "deploy:marketing": "sst deploy --target Marketing --stage production",
    "sso": "aws sso login --sso-session=lydie --use-device-code",
    "sdk:publish": "bun --filter=@lydie-app/sdk sdk:publish",
    "test": "bun --filter=@lydie/web test",
    "test:e2e": "bun --filter=@lydie/web test:e2e",
    "copy-integration-assets": "bun --filter=@lydie/scripts copy-integration-assets",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.66",
    "@fontsource/reenie-beanie": "^5.2.8",
    "@hocuspocus/provider": "^3.4.4",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "@tiptap/extension-code": "^3.20.1",
    "@tiptap/extension-table-of-contents": "^3.20.1",
    "framer-motion": "^12.36.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/bun": "^1.3.10",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "sst": "v3.18.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "prosemirror-view": "1.41.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.10",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
