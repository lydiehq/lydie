---
import { externalApiOpenApiSpec } from "@lydie/core/external-api-openapi";

import { Container } from "../../../components/Container";
import Layout from "../../../layouts/Layout.astro";

const methodClass: Record<string, string> = {
  get: "bg-emerald-50 text-emerald-700 border-emerald-200",
  post: "bg-blue-50 text-blue-700 border-blue-200",
  patch: "bg-amber-50 text-amber-700 border-amber-200",
  delete: "bg-rose-50 text-rose-700 border-rose-200",
};

const sampleCurl = `curl -X GET \\
  https://api.lydie.co/api/v1/collections/blog/documents?limit=10 \\
  -H 'Authorization: Bearer <API_KEY>'`;

const openApiUrl =
  process.env.LYDIE_OPENAPI_URL ||
  import.meta.env.LYDIE_OPENAPI_URL ||
  "https://api.lydie.co/api/v1/openapi.json";

type SpecPath = Record<string, { summary?: string; description?: string }>;
type OpenApiSpec = {
  openapi: string;
  info: { version: string };
  paths: Record<string, SpecPath>;
};

let renderedSpec: OpenApiSpec =
  externalApiOpenApiSpec as unknown as OpenApiSpec;
try {
  const response = await fetch(openApiUrl);
  if (response.ok) {
    renderedSpec = (await response.json()) as OpenApiSpec;
  }
} catch {
  renderedSpec = externalApiOpenApiSpec as unknown as OpenApiSpec;
}

const renderedEndpoints = Object.entries(renderedSpec.paths)
  .flatMap(([path, methods]) =>
    Object.entries(methods).map(([method, operation]) => ({
      method,
      path,
      summary: operation.summary ?? `${method.toUpperCase()} ${path}`,
      description: operation.description ?? "",
    })),
  )
  .sort((a, b) => a.path.localeCompare(b.path));
---

<Layout
  title="API Reference - Lydie"
  description="External API reference for collection documents with custom-styled docs on Lydie marketing pages."
>
  <Container className="py-12 max-w-5xl">
    <div class="space-y-10">
      <header class="space-y-4">
        <p class="text-sm font-medium text-blue-600">Developer Docs</p>
        <h1 class="text-4xl font-semibold text-gray-900">
          External API Reference
        </h1>
        <div
          class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-700"
        >
          <p>
            <span class="font-medium">OpenAPI:</span>
            {renderedSpec.openapi}
          </p>
          <p>
            <span class="font-medium">Version:</span>
            {renderedSpec.info.version}
          </p>
          <p>
            <span class="font-medium">Schema endpoint:</span>
            <code>/api/v1/openapi.json</code>
          </p>
        </div>
      </header>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-gray-900">Authentication</h2>
        <p class="text-gray-600">
          All endpoints require a bearer API key in the <code
            >Authorization</code
          > header.
        </p>
        <pre
          class="overflow-x-auto rounded-xl border border-gray-200 bg-gray-900 p-4 text-sm text-gray-100"><code>{sampleCurl}</code></pre>
      </section>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-gray-900">Endpoints</h2>
        <div class="space-y-3">
          {
            renderedEndpoints.map((endpoint) => (
              <article class="rounded-xl border border-gray-200 bg-white p-4">
                <div class="flex flex-wrap items-center gap-3">
                  <span
                    class={`inline-flex rounded-md border px-2 py-0.5 text-xs font-semibold uppercase ${methodClass[endpoint.method] ?? "bg-gray-50 text-gray-700 border-gray-200"}`}
                  >
                    {endpoint.method}
                  </span>
                  <code class="text-sm text-gray-800">
                    /api/v1{endpoint.path}
                  </code>
                </div>
                <h3 class="mt-2 text-lg font-semibold text-gray-900">
                  {endpoint.summary}
                </h3>
                <p class="mt-1 text-gray-600">{endpoint.description}</p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </Container>
</Layout>
